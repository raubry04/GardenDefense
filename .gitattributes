# Normalize line endings on checkout/commit
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ogg binary
*.mp3 binary
*.wav binary
*.ttf binary
*.woff binary
*.woff2 binary
